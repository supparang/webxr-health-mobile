function doGet(e){const p=e&&e.parameter||{},a=String(p.action||'health'),cb=String(p.callback||'');if(a==='health')return out_({ok:true,service:'HeroHealth_Groups_AR',version:GROUPS_AR_VERSION,serverTs:now_()},cb);if(a==='setup'){setupGroupsAR();return out_({ok:true,action:a,version:GROUPS_AR_VERSION,serverTs:now_()},cb)}if(a==='groupsDashboard'||a==='teacherConsole'){setupGroupsAR();return out_(dashboard_(p),cb)}return out_({ok:true,action:a,version:GROUPS_AR_VERSION,serverTs:now_()},cb)}
